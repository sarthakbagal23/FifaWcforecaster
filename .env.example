# GROQ_API_KEY: Required for AI prediction and tactical chat features.
# Users configure this via the Secrets panel in the AI Studio UI.
GROQ_API_KEY="MY_GROQ_API_KEY"

# FOOTBALL_DATA_API_KEY: Required for fetching live match data.
# Get an API key from https://www.football-data.org/
FOOTBALL_DATA_API_KEY="MY_FOOTBALL_DATA_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
